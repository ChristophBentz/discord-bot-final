# ============================================================
# Discord Bot
# ============================================================
# Bot-Token aus dem Discord-Developer-Portal (https://discord.com/developers/applications)
DISCORD_TOKEN=
# Application-ID (Client-ID) deiner Discord-App
DISCORD_CLIENT_ID=
# ID des Servers (Guild), auf dem der Bot laufen soll. Rechtsklick auf Server-Icon -> "Server-ID kopieren" (Entwicklermodus aktivieren).
DISCORD_GUILD_ID=

# ============================================================
# Web-Dashboard (Next.js + NextAuth)
# ============================================================
# Discord OAuth — gleiche App wie der Bot, aber zusätzlich unter "OAuth2" eine Redirect-URI eintragen:
#   http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_SECRET=

# Generieren mit:  openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Öffentliche URL fürs Dashboard — wird vom Bot benutzt um Profil-Links
# (/profil Slash-Command) zu erzeugen. Im Production-Setup auf https://deine-domain
# setzen. Fällt auf NEXTAUTH_URL zurück wenn leer.
PUBLIC_WEB_URL=http://localhost:3000

# Optionaler Notfall-Zugang fürs Dashboard. Discord-User-ID, die immer einloggen darf
# (auch wenn der Member-Sync ausgefallen ist oder die Mod-Rolle versehentlich entzogen wurde).
# Normale Logins laufen über Admin-/Mod-Rolle auf dem Server (Member.isProtected).
# Leer lassen, wenn du keinen Notfall-Zugang willst.
OWNER_DISCORD_ID=

# ============================================================
# Web ↔ Bot Bridge (HTTP-API, läuft auf Localhost)
# ============================================================
# Geteiltes Secret: muss in Bot und Web identisch sein.
# Generieren mit: openssl rand -hex 32
BOT_API_SECRET=
# URL, unter der das Web den Bot erreicht (Server-side fetch).
BOT_API_URL=http://localhost:4001
# Port, auf dem der Bot lauscht (default 4001).
BOT_API_PORT=4001

# ============================================================
# Datenbank (Prisma + SQLite)
# ============================================================
# Pfad relativ zum packages/db-Ordner. Standard reicht für lokale Entwicklung.
DATABASE_URL="file:./dev.db"

# ============================================================
# Branding (optional)
# ============================================================
# Footer-Text auf öffentlichen Seiten (/u/[id], /leaderboard).
# Lass beide leer für den Standard-Footer (moser-dev.com).
# NEXT_PUBLIC_-Prefix damit Next.js sie in den Client-Bundle einbaut.
NEXT_PUBLIC_BRAND_NAME=
NEXT_PUBLIC_BRAND_URL=

# Empfänger für die Feedback-Sektion in den Dashboard-Einstellungen.
# Leer = Standard (info@moser-dev.com).
NEXT_PUBLIC_FEEDBACK_EMAIL=

# ============================================================
# Feedback-Versand (optional)
# ============================================================
# Reihenfolge: 1. zentraler HTTP-Endpoint (kein Setup nötig) →
# 2. eigener SMTP-Zugang → 3. Mail-Programm des Users (mailto).
# Eigener Empfangs-Endpoint statt des Standards (scripts/feedback-endpoint.php
# auf einen Webspace hochladen). Leer = https://moser-dev.com/bot-feedback.php
FEEDBACK_ENDPOINT=

# SMTP-Fallback: Zugangsdaten eines Mail-Postfachs, über das das Dashboard
# Feedback-Mails direkt verschickt (nur nötig, wenn der Endpoint nicht genutzt
# werden soll).
SMTP_HOST=
# 587 = STARTTLS (Standard), 465 = TLS
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Absender-Adresse — leer = SMTP_USER
SMTP_FROM=
