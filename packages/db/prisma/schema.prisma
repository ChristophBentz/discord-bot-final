// Prisma-Schema für den Discord-Bot.
// Single-Guild-Setup: alle Settings leben in einer einzigen Config-Zeile.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Singleton: id = 1, immer genau eine Zeile.
model Config {
  id Int @id @default(1)

  // Bot-Presence (was Discord neben dem Bot-Namen anzeigt; leer = kein Status)
  botStatusText String?

  // Vom Bot synchronisiert — Dashboard zeigt das an.
  guildName        String?
  guildIconUrl     String?
  guildMemberCount Int     @default(0)
  botName          String?
  botAvatarUrl     String?
  botBannerUrl     String?

  // Dashboard-Akzentfarbe (Hex mit #; null = Standard Violet → Pink)
  accentFrom String?
  accentTo   String?

  // Logging — ein Channel, zuschaltbar pro Kategorie
  logChannelId      String?
  logMessageDelete  Boolean @default(false)
  logMessageEdit    Boolean @default(false)
  logMemberJoin     Boolean @default(false)
  logMemberLeave    Boolean @default(false)
  logMemberBan      Boolean @default(false)
  logMemberUnban    Boolean @default(false)
  logMemberNickname Boolean @default(false)
  logMemberRoles    Boolean @default(false)
  logVoice          Boolean @default(false)
  logModeration     Boolean @default(false) // Kick, Timeout, Warn (Ban/Unban läuft über logMemberBan/Unban)
  logChannels       Boolean @default(false) // Channels & Threads erstellt/gelöscht/geändert
  logServerRoles    Boolean @default(false) // Server-Rollen erstellt/gelöscht/geändert
  logServer         Boolean @default(false) // Server-Einstellungen (Name, Icon, AFK …)
  logInvites        Boolean @default(false) // Invites erstellt/gelöscht
  logEmojis         Boolean @default(false) // Emojis & Sticker

  // Mod-Aktionen zusätzlich in den Dashboard-Verlauf (ModEvent) schreiben —
  // unabhängig vom Log-Channel.
  recordModEvents Boolean @default(true)

  // Wenn true: nur der Owner + explizit freigegebene Mitglieder (AllowlistedUser)
  // kommen ins Dashboard — überschreibt die Permission-basierte Zugangslogik.
  accessAllowlistEnabled Boolean @default(false)
  // Wenn true (und Allowlist aktiv): die Mod-Slash-Commands (/ban, /kick …)
  // funktionieren nur noch für Owner + freigegebene Mitglieder.
  restrictCommandsToAllowlist Boolean @default(false)

  // Geburtstage
  birthdayEnabled   Boolean @default(false)
  birthdayChannelId String?
  birthdayMessage   String? // {user} {age} Platzhalter; leer = Standard
  birthdayPingRoleId String? // optionale Rolle, die zum Geburtstag gepingt wird
  birthdayLastRun   String? // Datums-Key (YYYY-MM-DD) der letzten Ankündigung — verhindert Doppelposts

  // Welcome / Leave
  welcomeEnabled   Boolean @default(false)
  welcomeChannelId String?
  welcomeMessage   String?
  leaveEnabled     Boolean @default(false)
  leaveChannelId   String?
  leaveMessage     String?
  autoRolesEnabled Boolean @default(false)

  // Moderation
  muteRoleId String?

  // AutoMod
  autoModEnabled            Boolean @default(false)
  autoModDM                 Boolean @default(false)
  autoModBypassMods         Boolean @default(false)
  autoModBlockInvites       Boolean @default(false)
  autoModMassMentionEnabled Boolean @default(false)
  autoModMassMentionLimit   Int     @default(5)
  autoModSpamEnabled        Boolean @default(false)
  autoModSpamMessages       Int     @default(5)
  autoModSpamSeconds        Int     @default(5)
  autoModSpamTimeoutMinutes Int     @default(5)
  autoModExcludedChannelsEnabled Boolean @default(false)

  // Scam-Bild-Erkennung (perceptual hashing gegen hinterlegte BlockedImage-Hashes)
  autoModImageEnabled        Boolean @default(false)
  autoModImageAction         String  @default("timeout") // "timeout" | "ban" | "delete"
  autoModImageTimeoutMinutes Int     @default(60)
  autoModImageThreshold      Int     @default(10) // max. Hamming-Distanz für einen Treffer

  // Leveling
  levelingEnabled    Boolean @default(false)
  levelUpChannelId   String?
  xpPerMessageMin    Int     @default(15)
  xpPerMessageMax    Int     @default(25)
  xpCooldownSeconds  Int     @default(60)
  xpPerMinuteVoice   Int     @default(5)
  // Level-Kurve: nächstes Level kostet `base * (1 + multiplier/100)^level` XP
  xpLevelBase        Int     @default(100)
  xpLevelMultiplier  Int     @default(15) // Prozent — z.B. 15 = 15% mehr XP pro Level
  // Level-Up-Nachricht. Platzhalter: {user} {username} {level} {server}
  levelUpMessage     String  @default("🎉 {user} ist auf **Level {level}** aufgestiegen!")

  // Achievements
  achievementNotifyDM      Boolean @default(false)
  achievementNotifyChannel Boolean @default(false)
  achievementChannelId     String?

  // Tickets
  ticketsEnabled            Boolean @default(false)
  ticketChannelId           String?
  ticketPanelMessageId      String?
  ticketCategoryId          String?
  ticketStaffRoleId         String?
  ticketTranscriptEnabled   Boolean @default(false)
  ticketTranscriptChannelId String?
  ticketRatingEnabled       Boolean @default(false)
  ticketRatingChannelId     String?

  // Temp-Voice-Channels (Join-to-Create) — Trigger leben in TempChannelTrigger
  tempChannelEnabled      Boolean @default(false)
  tempChannelCategoryId   String?
  tempChannelNameTemplate String  @default("🎙️ {nick}'s Channel")

  // Server-Stats — Locked-Voice-Channels mit Live-Zählerständen.
  // Einzelne Stats in ServerStat.
  serverStatsEnabled        Boolean @default(false)
  serverStatsCategoryId     String?
  serverStatsUpdateMinutes  Int     @default(10) // Update-Intervall in Minuten

  // Music — DJ-Rollen in MusicRole
  musicEnabled Boolean @default(false)

  // AI-Features — Bild-/Text-Generierung via externen Provider (MiniMax, OpenAI, …).
  aiEnabled              Boolean @default(false)
  aiProvider             String  @default("minimax") // "minimax" | "openai" | "stability" (future)
  aiApiKey               String? // wird auf dem Server gespeichert, nicht ins Web-Bundle exposed
  aiGroupId              String? // MiniMax-spezifisch (Group-ID aus dem Developer-Portal)
  aiImageChannelId       String? // einziger Channel in dem /image erlaubt ist (sonst Hinweis-Reply)
  aiImagesPerUserPerDay  Int     @default(5)
  aiImageModel           String  @default("image-01")
  aiApiBaseUrl           String  @default("https://api.minimaxi.com") // oder https://api.minimax.chat

  // Free Games — postet aktuelle Gratis-Aktionen via GamerPower
  freeGamesEnabled      Boolean @default(false)
  freeGamesChannelId    String?
  freeGamesEpic         Boolean @default(true)
  freeGamesSteam        Boolean @default(true)
  freeGamesGog          Boolean @default(true)
  freeGamesConsole      Boolean @default(false)
  freeGamesIncludeGames Boolean @default(true)
  freeGamesIncludeDlc   Boolean @default(false)
  freeGamesIncludeLoot  Boolean @default(false)
  freeGamesMessage      String?
  freeGamesPingRoleId   String?
  freeGamesFooterText   String?
  freeGamesLastCheck    DateTime?

  updatedAt DateTime @updatedAt
}

// Über das Dashboard verschickte Bot-Nachrichten — History + Bearbeiten/Löschen.
model BotMessage {
  id        Int      @id @default(autoincrement())
  channelId String
  messageId String   @unique
  type       String // "text" | "embed" | "poll" | "file" | "blocks"
  content    String?
  embedJson  String? // serialized EmbedSpec
  pollJson   String? // nur zur Anzeige — Polls können nicht editiert werden
  blocksJson String? // serialized BlocksSpec (Baukasten / Components V2)
  fileName   String?
  sentBy    String?
  sentAt    DateTime  @default(now())
  editedAt  DateTime?
}

// Dedup-Speicher — verhindert dass dasselbe Giveaway zweimal gepostet wird.
model FreeGamePost {
  giveawayId Int      @id
  title      String
  platform   String
  postedAt   DateTime @default(now())
  messageId  String?
}

// Rollen, die Musik abspielen + steuern dürfen.
model MusicRole {
  roleId  String   @id
  addedBy String?
  addedAt DateTime @default(now())
}

// Trigger-Channels für „Join-to-Create" — jeder mit eigenem User-Limit.
model TempChannelTrigger {
  channelId    String   @id
  userLimit    Int      @default(0)
  nameTemplate String? // Override für globales Template
  createdAt    DateTime @default(now())
}

// Aktive Temp-Voice-Channels.
model TempChannel {
  channelId      String   @id
  ownerId        String
  panelMessageId String?
  createdAt      DateTime @default(now())

  @@index([ownerId])
}

// Rollen, die jeder neue Member automatisch bekommt.
model AutoRole {
  id      Int      @id @default(autoincrement())
  roleId  String   @unique
  addedAt DateTime @default(now())
}

// RSS-Feeds — pro Feed eigener Channel, Intervall, optional Ping-Rolle.
model RssFeed {
  id             Int       @id @default(autoincrement())
  name           String
  url            String
  channelId      String
  pingRoleId     String?
  intervalMin    Int       @default(15)
  maxPostsPerRun Int       @default(5)
  enabled        Boolean   @default(true)
  lastCheck      DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  items RssFeedItem[]
}

// Dedup-Speicher — verhindert dass derselbe Artikel zweimal gepostet wird.
model RssFeedItem {
  id        Int      @id @default(autoincrement())
  feedId    Int
  guid      String
  title     String
  link      String?
  postedAt  DateTime @default(now())
  messageId String?

  feed RssFeed @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@unique([feedId, guid])
  @@index([feedId, postedAt])
}

// Self-Assign-Rollen-Panel — eine Discord-Nachricht via die User sich
// Rollen selbst geben können. Drei Modi: Reaction (Emoji-Reaktionen),
// Button (klickbare Buttons), Dropdown (StringSelectMenu).
model SelfRolePanel {
  id           Int       @id @default(autoincrement())
  channelId    String
  messageId    String? // null bis der Bot die Nachricht gepostet hat
  type         String // "reaction" | "button" | "dropdown"
  title        String
  description  String?
  color        Int? // Embed-Farbe als RGB-Integer
  uniqueChoice Boolean   @default(false) // wenn true: pro Panel max. eine Rolle (alte wird entfernt)
  useEmbed     Boolean   @default(true) // false = nur normale Nachricht ohne Embed-Box
  enabled      Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  options SelfRoleOption[]

  @@index([channelId])
}

model SelfRoleOption {
  id          Int           @id @default(autoincrement())
  panelId     Int
  panel       SelfRolePanel @relation(fields: [panelId], references: [id], onDelete: Cascade)
  roleId      String
  label       String
  description String? // gezeigt im Dropdown als Untertitel
  emoji       String? // Reaction-Emoji ODER Icon im Button/Dropdown
  buttonStyle String? // "primary" | "secondary" | "success" | "danger"
  position    Int           @default(0)

  @@unique([panelId, roleId])
}

// Server-Stats — pro Eintrag ein automatisch erzeugter Voice-Channel mit
// Live-Zählerstand im Namen.
model ServerStat {
  id           Int       @id @default(autoincrement())
  type         String // "totalMembers" | "humanMembers" | "onlineMembers"
  nameTemplate String // z.B. "📊 Mitglieder: {count}"
  channelId    String? // null bis der Bot den Channel angelegt hat
  position     Int       @default(0)
  enabled      Boolean   @default(true)
  lastValue    Int?
  lastCheck    DateTime? // Jeder Scheduler-Tick (auch wenn nichts geändert)
  lastUpdate   DateTime? // Nur wenn der Channel-Name tatsächlich neu gesetzt wurde
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// AutoMod ausgenommene Channels — keine Regel greift in diesen Channels.
model AutoModExcludedChannel {
  channelId String   @id
  addedAt   DateTime @default(now())
  addedBy   String?
}

// Rollen, die vom AutoMod-Filter ausgenommen sind (wenn autoModBypassMods aktiv ist).
model AutoModBypassRole {
  roleId  String   @id
  addedBy String?
  addedAt DateTime @default(now())
}

// Erlaubte Discord-Server — Invites werden via Guild-ID matched, damit beliebige Codes vom gleichen Server durchgehen.
model WhitelistedInvite {
  id        Int      @id @default(autoincrement())
  guildId   String   @unique
  guildName String?
  note      String?
  addedBy   String?
  createdAt DateTime @default(now())
}

// AutoMod-Wortliste.
model BlacklistedWord {
  id        Int      @id @default(autoincrement())
  word      String   @unique // case-insensitive verglichen, hier lowercase gespeichert
  addedBy   String?
  createdAt DateTime @default(now())

  @@index([word])
}

// Mod-Warnungen.
model Warning {
  id          Int      @id @default(autoincrement())
  userId      String
  moderatorId String
  reason      String
  createdAt   DateTime @default(now())

  @@index([userId])
}

// Protokoll von Mod-Aktionen (Kick, Timeout, Voice-Move/-Disconnect) fürs Dashboard.
// Wird vom Bot bei Discord-Events geschrieben — egal ob im Dashboard oder direkt
// in Discord ausgeführt. Warnings haben ihre eigene Tabelle.
model ModEvent {
  id          Int      @id @default(autoincrement())
  userId      String // betroffener User
  moderatorId String? // null = unbekannt (z.B. kein Audit-Log-Zugriff)
  action      String // kick | timeout | timeoutEnd | voiceMove | voiceDisconnect
  detail      String? // z.B. "Lobby → AFK", Dauer oder Grund
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Aktive Mutes (für Timeout-Wiederherstellung nach Bot-Restart).
model Mute {
  id        Int      @id @default(autoincrement())
  userId    String   @unique
  reason    String?
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// Leveling pro User.
model LevelUser {
  userId       String   @id
  displayName  String?
  xp           Int      @default(0)
  level        Int      @default(0)
  messageCount Int      @default(0)
  voiceSeconds Int      @default(0)
  lastMessage  DateTime @default(now())
}

// Rollen, die bei einem bestimmten Level vergeben werden.
model LevelReward {
  level  Int    @id
  roleId String
}

// Tickets.
model Ticket {
  id        Int       @id @default(autoincrement())
  channelId String    @unique // Discord-Thread-ID
  userId    String
  username  String?
  topic     String?
  status    String    @default("open") // "open" | "closed"
  createdAt DateTime  @default(now())
  closedAt  DateTime?
  closedBy  String?

  // Bewertung nach Schließen (User wird via DM gefragt)
  rating        Int?
  ratingComment String?
  ratingAt      DateTime?

  messages TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([closedBy])
}

// Einzelne Nachrichten im Ticket-Thread.
model TicketMessage {
  id         Int      @id @default(autoincrement())
  ticketId   Int
  authorId   String
  authorName String
  fromMod    Boolean  @default(false)
  content    String
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

// Vom User im Dashboard definierte Custom-Slash-Commands.
// Werden bei jeder Änderung als echte Guild-Commands bei Discord registriert.
model CustomCommand {
  name        String   @id // Discord-Slash-Name (lowercase, 1-32 chars, regex ^[\w-]{1,32}$)
  description String   @default("Custom-Command") // 1-100 chars, vom User editierbar
  // "text" = einfache Text-Antwort, "embed" = Embed mit Title/Description/Color
  responseType String  @default("text")
  // Text-Mode: response wird direkt geschickt (mit Placeholder-Substitution).
  // Embed-Mode: optional als Embed-Description, falls embedDescription leer.
  response    String   @default("")
  // Embed-Felder (nur relevant wenn responseType = "embed")
  embedTitle       String?
  embedDescription String?
  embedColor       Int?     // 0xRRGGBB
  embedImageUrl    String?
  embedFooter      String?
  // Nur Aufrufer sieht die Antwort
  ephemeral   Boolean  @default(false)
  // Komma-separierte Role-IDs die den Command nutzen dürfen. Leer = alle.
  allowedRoleIds String @default("")
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// AI-Generierungen pro User — für Rate-Limit + Dashboard-Stats.
model AiUsage {
  id        Int      @id @default(autoincrement())
  userId    String
  command   String   // "image" | "chat" | "video" (für Zukunft)
  provider  String   // "minimax" | "openai" …
  prompt    String   // gespeichert für Stats/Audit, max 1000 chars
  imageUrl  String?  // Discord-Attachment-URL falls Bild
  success   Boolean  @default(true)
  errorMsg  String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// Synchronisiert vom Bot — alle bekannten Server-Mitglieder.
model Member {
  userId             String    @id
  username           String
  displayName        String
  // NFKC-normalisiert + lowercase (displayName + username) — macht Namen mit
  // Unicode-Schriftarten (𝑺𝒏𝒐𝒐𝒌𝒚) und Akzenten durchsuchbar. Vom Bot-Sync gepflegt.
  searchName         String?
  discriminator      String?
  avatarUrl          String?
  // User-Banner-Hash (für Profile-Page) — wird per Discord-API on-demand gefetcht
  bannerUrl          String?
  accentColor        Int?
  bannerRefreshedAt  DateTime?
  joinedAt           DateTime?
  roleIds            String    @default("")
  isBot              Boolean   @default(false)
  inServer           Boolean   @default(true)
  isProtected        Boolean   @default(false) // Owner / Admin / Mod — vor Kick/Ban/Timeout geschützt
  // Öffentliches Profil unter /u/[userId]. Wenn false sehen Fremde nur Name+Avatar.
  profilePublic      Boolean   @default(true)
  // Geburtstag — Tag/Monat (Jahr optional). Vom User via /geburtstag gesetzt.
  birthdayDay        Int?
  birthdayMonth      Int?
  birthdayYear       Int?
  birthdayShow       Boolean   @default(true) // im öffentlichen Profil zeigen
  birthdayShowAge    Boolean   @default(true) // Alter zeigen (nur wenn Jahr gesetzt)
  birthdayAnnounce   Boolean   @default(true) // im Geburtstags-Channel ankündigen
  // Giveaway-Privatsphäre
  giveawayShowEntries Boolean  @default(true) // Teilnahmen im Profil zeigen
  giveawayShowWins    Boolean  @default(true) // Gewinne im Profil zeigen
  giveawayWinDm       Boolean  @default(true) // DM bei Gewinn erhalten
  // Wird inkrementiert via /profil reset — invalidiert alte Magic-Links.
  profileTokenVersion Int      @default(0)
  lastSyncAt         DateTime  @default(now())

  @@index([displayName])
  @@index([inServer])
  @@index([birthdayMonth, birthdayDay])
}

// Synchronisierte Server-Rollen.
model GuildRole {
  roleId   String @id
  name     String
  color    Int    @default(0)
  position Int    @default(0)
  // true wenn die Rolle gefährliche Permissions trägt (Administrator,
  // Rollen/Server/Channels/Webhooks verwalten, Ban, Kick) — vom Bot-Sync
  // gesetzt. Solche Rollen werden nie über das Dashboard vergeben.
  privileged Boolean @default(false)
  // true für Integrations-/Booster-Rollen (managed) — nicht manuell vergebbar.
  managed    Boolean @default(false)
  // true wenn die Rolle Dashboard-Zugang gewährt (Administrator, Kick, Ban
  // oder Timeout) — vom Bot-Sync gesetzt, für die Übersicht in den Einstellungen.
  grantsAccess Boolean @default(false)

  @@index([position])
}

// Vom Owner manuell gesperrte Rollen — werden im Dashboard nicht zur
// Vergabe angeboten. Nur OWNER_DISCORD_ID kann die Liste bearbeiten.
model BlockedRole {
  roleId    String   @id
  createdAt DateTime @default(now())
}

// Explizit fürs Dashboard freigegebene Mitglieder — nur relevant wenn
// Config.accessAllowlistEnabled true ist. Nur der Owner pflegt die Liste.
model AllowlistedUser {
  userId    String   @id
  createdAt DateTime @default(now())
}

// Hinterlegte Scam-Bilder für die AutoMod-Bilderkennung.
model BlockedImage {
  id          Int      @id @default(autoincrement())
  hash        String // perceptual hash (dHash, 16 Hex-Zeichen)
  label       String // vom Mod vergebener Name
  thumbnail   String? // kleines Vorschau-Thumbnail (data-URL) fürs Dashboard
  addedBy     String
  createdAt   DateTime @default(now())

  @@index([hash])
}

// Giveaways — vom Dashboard erstellt, Bot postet/verwaltet die Nachricht.
model Giveaway {
  id             Int      @id @default(autoincrement())
  channelId      String
  messageId      String? // gesetzt, sobald die Giveaway-Nachricht gepostet wurde
  prize          String
  description    String?
  // Bild zum Giveaway (Discord-CDN-URL nach Upload oder direkt eingegebene URL).
  imageUrl       String?
  // Gewinn-Code(s): eine Zeile pro Code. Mehrere Zeilen = ein eigener Code je
  // Gewinner. Wird dem Gewinner per DM zugeschickt, nie öffentlich im Channel.
  rewardCode     String?
  // Bonus-Lose pro Rolle als JSON: [{"roleId":"...","extra":2}] — Transparenz/Gewichtung.
  bonusRolesJson String?
  winnerCount    Int      @default(1)
  hostId         String // wer das Giveaway erstellt hat
  // Teilnahme-Kriterien (alle optional)
  minLevel       Int?
  requiredRoleId String?
  minMemberDays  Int?
  endsAt         DateTime
  ended          Boolean  @default(false)
  createdAt      DateTime @default(now())

  entries GiveawayEntry[]

  @@index([ended, endsAt])
}

model GiveawayEntry {
  id           Int      @id @default(autoincrement())
  giveawayId   Int
  userId       String
  tickets      Int      @default(1) // Anzahl Lose (Basis 1 + Bonus-Rollen) — transparent
  isWinner     Boolean  @default(false)
  assignedCode String? // bei Gewinn zugewiesener Code (aus der Code-Liste)
  dmStatus     String? // "sent" | "failed" | "disabled" — Zustellungsstatus der Gewinn-DM
  enteredAt    DateTime @default(now())

  giveaway Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)

  @@unique([giveawayId, userId])
  @@index([userId])
}

// Vom Bot synchronisiert — alle Text-fähigen Server-Channels.
model GuildChannel {
  channelId String  @id
  name      String
  type      Int     @default(0)
  parentId  String?
  position  Int     @default(0)

  @@index([position])
}

// Nachrichten-Aktivität pro User & Channel & Tag.
model ChannelActivity {
  userId    String
  channelId String
  date      String
  messages  Int    @default(0)

  @@id([userId, channelId, date])
  @@index([userId, date])
  @@index([channelId])
}

// Pro-Stunde-Aktivität pro User (für Heat-Map mit Tageszeit-Buckets).
model HourlyActivity {
  userId       String
  date         String
  hour         Int
  messages     Int    @default(0)
  voiceSeconds Int    @default(0)

  @@id([userId, date, hour])
  @@index([userId])
  @@index([date])
}

// Definition eines Achievements.
model Achievement {
  id           Int      @id @default(autoincrement())
  name         String
  description  String
  imageUrl     String?  // /uploads/achievements/<id>.<ext>
  // "manual" | "level" | "messages" | "voice" | "xp"
  triggerType  String   @default("manual")
  triggerValue Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  awards UserAchievement[]

  @@index([triggerType, triggerValue])
}

// User hat ein Achievement freigeschaltet.
model UserAchievement {
  id            Int      @id @default(autoincrement())
  userId        String
  achievementId Int
  awardedAt     DateTime @default(now())
  awardedBy     String?  // null = automatisch, sonst Moderator-ID

  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

// Staff-Notizen zu einem Member.
model MemberNote {
  id         Int      @id @default(autoincrement())
  userId     String
  authorId   String
  authorName String
  content    String
  createdAt  DateTime @default(now())

  @@index([userId])
}

// Ban-Appeal: gebannter User reicht über die öffentliche Appeal-Seite eine Begründung ein.
model BanAppeal {
  id           Int       @id @default(autoincrement())
  userId       String
  username     String // Snapshot — User ist nach dem Ban evtl. nicht mehr im Member-Sync
  banReason    String?
  text         String // Begründung des Users
  // "pending" | "approved" | "denied"
  status       String    @default("pending")
  decidedById  String?
  decidedBy    String? // Moderator-Name
  decidedAt    DateTime?
  decisionNote String? // optionale Begründung der Entscheidung (auf der Appeal-Seite sichtbar)
  inviteUrl    String? // Einmal-Invite nach angenommenem Antrag — auf der Appeal-Seite sichtbar
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([status])
}

// Invite-Tracking: über welchen Invite ein Member gejoint ist.
model InviteUse {
  id         Int      @id @default(autoincrement())
  userId     String
  inviterId  String? // null = nicht zuordenbar (Vanity-URL, abgelaufener Invite, …)
  inviteCode String?
  joinedAt   DateTime @default(now())

  @@index([userId])
  @@index([inviterId])
}
